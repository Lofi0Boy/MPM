{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".mpm/scripts/hook-notify.sh active" },
          { "type": "command", "command": ".mpm/scripts/hook-init-check.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".mpm/scripts/hook-notify.sh working" },
          { "type": "command", "command": ".mpm/scripts/hook-task-reminder.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".mpm/scripts/hook-pretool-task-check.sh" }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".mpm/scripts/hook-notify.sh waiting" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".mpm/scripts/hook-notify.sh waiting" },
          { "type": "command", "command": ".mpm/scripts/hook-autonext-stop.sh" }
        ]
      }
    ]
  }
}
